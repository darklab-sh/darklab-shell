# VSCode
.vscode/

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Vendor JS files are committed as a fallback for local/docker-compose runs.
# The Dockerfile overwrites them with the latest version at image build time.
# Ignore any other files that may accumulate in the vendor directory.
app/static/js/vendor/*
!app/static/js/vendor/ansi_up.js
!app/static/js/vendor/jspdf.umd.min.js
!app/static/js/vendor/xterm-addon-fit.js
!app/static/js/vendor/xterm.css
!app/static/js/vendor/xterm.js
 
# Persistent workspaces bind mount, if in use
workspaces/

# Persistent data (SQLite run history — contains user data, should not be committed)
data/

# Optional local config overlay for production/server-specific overrides.
*.local.*
 
# Node / JS tooling
node_modules/
playwright-report/
test-results/

# Environment overrides (copy .env.example → .env and edit locally)
.env

# OS
.DS_Store
Thumbs.db
