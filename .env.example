# Port the app listens on inside the container.
# This file takes precedence over the fallback defaults in docker-compose.yml and Dockerfile.
APP_PORT=8888

# Optional Gunicorn runtime sizing.
# Uncomment to override the entrypoint defaults:
# WEB_CONCURRENCY=4
# WEB_THREADS=4

# Optional GELF target for the production override.
# Set this when running:
#   docker compose -f docker-compose.yml -f examples/docker-compose.prod.yml up -d
# DOCKER_GELF_ADDRESS=udp://loghost.darklab.sh:12201/
