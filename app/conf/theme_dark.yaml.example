# darklab_shell — Theme Reference Template
# -------------------------------------------
# Copy this file to app/conf/themes/<filename>.yaml to create a selectable
# theme variant. The runtime selector ignores *.yaml.example files and only
# scans app/conf/themes/*.yaml.
# Full reference: THEME.md
# label: is optional and becomes the friendly name shown in the theme preview
# modal. If omitted, the selector falls back to a humanized filename stem.
# group: is optional and controls the preview-modal section header.
# sort: is optional and controls ordering within the modal and between groups.
# Theme values are plain CSS strings. You may reference other resolved theme
# variables with CSS var(--name) syntax, or use CSS functions like color-mix();
# the browser resolves those strings after the theme vars are injected.
# app/conf/config.yaml default_theme should point at a full filename from
# app/conf/themes/ (for example darklab_obsidian.yaml).
# All values are CSS color strings (hex, rgb, rgba, hsl, etc.) or other valid
# CSS values for the given key.
# Changes take effect after a container restart (docker compose restart).
# No rebuild needed.
#
# Leave a value commented out or omit it entirely to keep the app's built-in
# fallback defaults from app/config.py.

color_scheme: dark

# ── Backgrounds ───────────────────────────────────────────────────────────────

# Page background (body) — shown around and behind the terminal window
bg: "#000000"

# Surface background — used for modals, panels, and dropdowns
surface: "#141414"

# ── Borders ───────────────────────────────────────────────────────────────────

# Subtle border (dividers, section separators)
border: "#2a2a2a"

# Prominent border (input focus rings, modal outlines)
border_bright: "#3c3c3c"

# Soft border (low-contrast separators inside denser chrome)
border_soft: "rgba(255, 255, 255, 0.08)"

# ── Text ──────────────────────────────────────────────────────────────────────

# Primary text color
text: "#e0e0e0"

# Muted / secondary text color (labels, hints, timestamps)
muted: "#9a9a9a"

# ── Accent Colors ─────────────────────────────────────────────────────────────

# Primary green — used for the terminal prompt, run button, highlights, and
# success indicators
green: "#39ff14"

# Dimmed green — used for borders, focus rings, and subtle highlights
green_dim: "#1a7a08"

# Green glow — used for box-shadows and background tints (should be rgba)
green_glow: "rgba(57,255,20,0.12)"

# Amber — used for warnings, the RUNNING status pill, starred items, and
# denied-command messages
amber: "#ffb800"

# Red — used for errors, the FAIL/KILLED status, and the kill-task modal border
red: "#ff3c3c"

# Blue — used for the prompt prefix, welcome screen labels, notice lines, and command badges
blue: "#6ab0f5"

# ── Typography ────────────────────────────────────────────────────────────────

# Terminal output font size
terminal_font_size: "14px"

# Terminal output line height
terminal_line_height: "1.65"

# ── Component Chrome ─────────────────────────────────────────────────────────

# Text used for the live prompt line shown above the hidden input
prompt_line_text: "#e8e8e8"

# Terminal panes / panels / shell chrome
panel_bg: "#141414"
panel_border: "#3c3c3c"
panel_shadow: "rgba(170,170,170,0.12)"
terminal_bar_bg: "#000000"
chrome_bg: "#0c0c0c"
chrome_header_bg: "#0c0c0c"
chrome_row_bg: "#0c0c0c"
chrome_row_hover_bg: "rgba(57,255,20,0.12)"
chrome_control_bg: "color-mix(in srgb, var(--surface) 92%, transparent)"
chrome_control_border: "var(--border-bright)"
chrome_divider_color: "#2a2a2a"
chrome_shadow: "rgba(0,0,0,0.6)"

# Header / toolbar buttons
toolbar_button_bg: "transparent"
toolbar_button_border: "#3c3c3c"
toolbar_button_text: "#9a9a9a"
toolbar_button_hover_bg: "transparent"
toolbar_button_hover_border: "#1a7a08"
toolbar_button_hover_text: "#39ff14"
toolbar_button_active_bg: "rgba(57,255,20,0.06)"
toolbar_button_active_border: "#1a7a08"
toolbar_button_active_text: "#39ff14"

# Tabs bar / tabs
tabs_bar_scrollbar_track: "rgba(255,255,255,0.06)"
tabs_bar_scrollbar_thumb: "#6d6d6d"
tabs_bar_scrollbar_thumb_hover: "#8a8a8a"
tab_bg: "linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01))"
tab_border: "#3c3c3c"
tab_text: "#9a9a9a"
tab_hover_text: "#e0e0e0"
tab_active_bg: "rgba(57,255,20,0.04)"
tab_active_border: "color-mix(in srgb, var(--green) 42%, transparent)"
tab_active_text: "#39ff14"
tab_active_shadow: "none"
tab_close_bg: "rgba(255,255,255,0.02)"
tab_close_border: "rgba(255,255,255,0.06)"
tab_close_hover_bg: "color-mix(in srgb, var(--green-dim) 18%, transparent)"
tab_close_hover_border: "color-mix(in srgb, var(--green-dim) 30%, transparent)"
tab_close_hover_text: "inherit"
tab_touch_drag_text_shadow: "0 0 10px color-mix(in srgb, var(--green) 14%, transparent)"
tab_drop_shadow: "0 0 10px color-mix(in srgb, var(--green) 45%, transparent)"

# Restore overlay
history_load_overlay_bg: "rgba(0,0,0,0.76)"

# Modals
modal_bg: "#141414"

# Dropdowns / autocomplete / app-native selects
dropdown_bg: "color-mix(in srgb, var(--surface) 96%, transparent)"
dropdown_border: "color-mix(in srgb, var(--green) 18%, transparent)"
dropdown_shadow: "rgba(0,0,0,0.35)"
dropdown_item_text: "#9a9a9a"
overlay_backdrop_bg: "rgba(0,0,0,0.76)"

# Inline surfaces
inline_surface_bg: "#141414"

# Toasts
toast_bg: "#141414"
toast_text: "#39ff14"
toast_border: "#1a7a08"
toast_error_bg: "color-mix(in srgb, var(--red) 8%, var(--bg))"
toast_error_text: "#ff3c3c"
toast_error_border: "color-mix(in srgb, var(--red) 45%, transparent)"

# Welcome / onboarding styling
welcome_ascii_color: "var(--green)"
welcome_command_hover_bg: "color-mix(in srgb, var(--green) 6%, transparent)"
welcome_command_hover_shadow: "0 0 0 1px var(--green-glow)"
welcome_ascii_text_shadow: "0 0 10px color-mix(in srgb, var(--green) 14%, transparent), 0 0 4px color-mix(in srgb, var(--green) 18%, transparent), 0 1px 0 rgba(8,16,12,0.4)"
welcome_ascii_filter: "saturate(1.12) contrast(1.08) brightness(1.08)"

# Action / selection text colors
on_accent_text: "#000"
selection_text: "#f7fff2"
selection_line_text: "#eef7ee"
modal_danger_btn_text: "#fff"
modal_warning_btn_text: "#000"
