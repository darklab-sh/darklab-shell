#!/usr/bin/env bash
# Pre-commit checks: flake8, bandit, pytest, pip-audit
# Install once with: git config core.hooksPath .githooks

set -uo pipefail

# Resolve the repo root (the directory containing .githooks/)
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Use the .venv Python if present, otherwise fall back to whatever is on PATH
if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON="$REPO_ROOT/.venv/bin/python"
else
    PYTHON="python"
fi

PASS=0
FAIL=0
FAILURES=()

run_check() {
    local name="$1"
    shift
    printf "\n\033[1m[pre-commit]\033[0m %s ... " "$name"
    if "$@"; then
        printf "\033[32mPASS\033[0m\n"
        PASS=$((PASS + 1))
    else
        printf "\033[31mFAIL\033[0m\n"
        FAIL=$((FAIL + 1))
        FAILURES+=("$name")
    fi
}

run_check "flake8"    "$PYTHON" -m flake8 app/ tests/py/
run_check "bandit"    "$PYTHON" -m bandit -r app/ -ll -q
run_check "pytest"    "$PYTHON" -m pytest tests/py/ -q --tb=short
run_check "pip-audit" "$PYTHON" -m pip_audit -r app/requirements.txt -r requirements-dev.txt

# JS unit tests (Vitest) — run if npm is available and node_modules exist
if command -v npm >/dev/null 2>&1 && [ -d "$REPO_ROOT/node_modules" ]; then
    run_check "vitest" npm --prefix "$REPO_ROOT" run test:unit
fi

printf "\n\033[1m[pre-commit]\033[0m %d passed" "$PASS"
if [ "$FAIL" -gt 0 ]; then
    printf ", \033[31m%d failed: %s\033[0m" "$FAIL" "${FAILURES[*]}"
    printf "\n"
    exit 1
fi
printf "\n"
