[flake8]
max-line-length = 130
# E302/E305: single blank lines between functions — intentional in this codebase,
#             visual separation is provided by section header comments.
# E221/E272: extra whitespace used deliberately for column alignment.
# E127:      continuation line indent — style choice.
extend-ignore = E302, E305, E221, E272, E127
per-file-ignores =
    # E402: sys.path manipulation must precede app import in all test files
    tests/test_validation.py: E402
    tests/test_utils.py: E402
    tests/test_routes.py: E402
    tests/test_logging.py: E402
    # E402: configure_logging(CFG) must run before local imports that connect
    #       to Redis at module-import time (process.py), so those imports follow it
    app/app.py: E402
